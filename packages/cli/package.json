{
  "name": "@mcptoolshop/loadout-os",
  "version": "1.0.2",
  "description": "Unified Knowledge OS CLI — wraps ai-loadout (kernel) + claude-memories + claude-rules and absorbs the operational rituals (doctor, report, refresh) into one loadout-os binary.",
  "license": "MIT",
  "author": "mcp-tool-shop",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/loadout-os.git"
  },
  "homepage": "https://github.com/mcp-tool-shop-org/loadout-os#readme",
  "bugs": "https://github.com/mcp-tool-shop-org/loadout-os/issues",
  "bin": {
    "loadout-os": "dist/loadout-os.js"
  },
  "files": [
    "dist/loadout-os.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.config.mjs",
    "test": "node --test dist/tests/*.test.js",
    "verify": "tsc --noEmit && node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "devDependencies": {
    "@mcptoolshop/ai-loadout": "^1.4.3",
    "@mcptoolshop/claude-memories": "^1.0.3",
    "@mcptoolshop/claude-rules": "^1.2.2",
    "@types/node": "^22",
    "typescript": "^5.7",
    "esbuild": "^0.28.1",
    "c8": "^11"
  },
  "engines": {
    "node": ">=20"
  }
}
